{
  "version": 2,
  "outputDirectory": ".",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/locations(.html)?",
      "headers": { "Location": "/tiers" },
      "status": 301
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-create-rooms",
      "schedule": "0 0 * * *"
    }
  ]
}
