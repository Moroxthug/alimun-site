# ============================================================
#  ALIMUN — Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to version control.
# ============================================================

# ── APP ─────────────────────────────────────────────────────
APP_URL=https://alimun.com
ADMIN_EMAIL=admin@alimun.com
ADMIN_SECRET=your_admin_secret_for_teacher_approval_hmac


# ── SUPABASE ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# ── STRIPE ───────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
# Found in: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

# Stripe Price IDs — EUR Monthly subscriptions
# Found in: Stripe Dashboard → Products → [product] → Prices
STRIPE_PRICE_COMMUNITY_MONTHLY=price_COMMUNITY_MONTHLY_ID
STRIPE_PRICE_FOCUSED_MONTHLY=price_FOCUSED_MONTHLY_ID
STRIPE_PRICE_INTENSIVE_MONTHLY=price_INTENSIVE_MONTHLY_ID
STRIPE_PRICE_PRIVATE_MONTHLY=price_PRIVATE_MONTHLY_ID

# Stripe Price IDs — EUR Yearly subscriptions
STRIPE_PRICE_COMMUNITY_YEARLY=price_COMMUNITY_YEARLY_ID
STRIPE_PRICE_FOCUSED_YEARLY=price_FOCUSED_YEARLY_ID
STRIPE_PRICE_INTENSIVE_YEARLY=price_INTENSIVE_YEARLY_ID
STRIPE_PRICE_PRIVATE_YEARLY=price_PRIVATE_YEARLY_ID

# Stripe Price IDs — One-time payments (EUR only)
# 1-on-1 session = €25, Certificate = €19
STRIPE_PRICE_ONEONONE_SESSION=price_ONEONONE_SESSION_ID
STRIPE_PRICE_CERTIFICATE=price_CERTIFICATE_ID

# Stripe Price IDs — AUD Monthly (regional, separate Price objects on same Product)
STRIPE_PRICE_COMMUNITY_MONTHLY_AUD=price_COMMUNITY_MONTHLY_AUD_ID
STRIPE_PRICE_FOCUSED_MONTHLY_AUD=price_FOCUSED_MONTHLY_AUD_ID
STRIPE_PRICE_INTENSIVE_MONTHLY_AUD=price_INTENSIVE_MONTHLY_AUD_ID
STRIPE_PRICE_PRIVATE_MONTHLY_AUD=price_PRIVATE_MONTHLY_AUD_ID

# Stripe Price IDs — MAD Monthly (regional, separate Price objects on same Product)
STRIPE_PRICE_COMMUNITY_MONTHLY_MAD=price_COMMUNITY_MONTHLY_MAD_ID
STRIPE_PRICE_FOCUSED_MONTHLY_MAD=price_FOCUSED_MONTHLY_MAD_ID
STRIPE_PRICE_INTENSIVE_MONTHLY_MAD=price_INTENSIVE_MONTHLY_MAD_ID
STRIPE_PRICE_PRIVATE_MONTHLY_MAD=price_PRIVATE_MONTHLY_MAD_ID

# ── DAILY.CO ─────────────────────────────────────────────────
# Found in: Daily.co Dashboard → Developers → API keys
DAILY_CO_API_KEY=YOUR_DAILY_CO_API_KEY
# Found in: Daily.co Dashboard → Your domain name (e.g. alimun)
DAILY_CO_DOMAIN=alimun

# ── RESEND ───────────────────────────────────────────────────
# Found in: Resend Dashboard → API Keys → Create API key
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# ── WISE BUSINESS (payouts) ───────────────────────────────────
# Found in: Wise Developer → API tokens
# Used server-side only — never expose in browser
WISE_API_TOKEN=YOUR_WISE_API_TOKEN
WISE_PROFILE_ID=YOUR_WISE_PROFILE_ID
# Environment: 'sandbox' or 'live'
WISE_ENVIRONMENT=live
